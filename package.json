{
  "name": "@metamask/skills",
  "version": "0.0.0",
  "description": "Shared MetaMask agent skills installer and sync CLI.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "metamask-skills": "bin/metamask-skills.mjs"
  },
  "files": [
    "bin/",
    "domains/",
    "tools/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "smoke": "node bin/metamask-skills.mjs --help",
    "build": "node bin/metamask-skills.mjs --help",
    "test": "node --test test/*.test.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "changelog:validate": "bash scripts/validate-changelog.sh",
    "create-release-branch": "create-release-branch --formatter oxfmt"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MetaMask/skills.git"
  },
  "engines": {
    "node": "^18.18 || >=20"
  },
  "packageManager": "yarn@4.16.0",
  "devDependencies": {
    "@metamask/auto-changelog": "^6.1.1",
    "@metamask/create-release-branch": "^4.2.1",
    "oxfmt": "^0.45.0"
  }
}
